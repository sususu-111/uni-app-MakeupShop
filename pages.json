{
	"easycom": {
	  "autoscan": true,
	  "custom": {
	    "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
	  }
	},
	"pages": [ //pages数组中第一项表示应用启动页，参考：https://uniapp.dcloud.io/collocation/pages
		{
			"path": "pages/index/index",
			"style": {
				"navigationBarTitleText": "首页"
			}
		},
		{
			"path": "pages/classify/classify",
			"style": {
				"navigationBarTitleText": "分类"
			}
		},
		{
			"path": "pages/cart/cart",
			"style": {
				"navigationBarTitleText": "购物车"
			}
		},
		{
			"path": "pages/user/user",
			"style": {
				"navigationBarTitleText": "用户"
			}
		}
	],
	"tabBar": {
		"color": "#333",
		"selectedColor": "#5756B3",
		"backgroundColor": "#fff",
		"borderStyle": "white",
		"list":[
			{
				"text": "首页",
				"pagePath":"pages/index/index",
				"iconPath": "/static/TabbarLogo/index.svg",
				"selectedIconPath": "/static/TabbarLogo/index-a.svg"
			},{
				"text": "分类",
				"pagePath":"pages/classify/classify",
				"iconPath": "/static/TabbarLogo/classify.svg",
				"selectedIconPath": "/static/TabbarLogo/classify-a.svg"
			},{
				"text": "购物车",
				"pagePath":"pages/cart/cart",
				"iconPath": "/static/TabbarLogo/cart.svg",
				"selectedIconPath": "/static/TabbarLogo/cart-a.svg"
			},{
				"text": "我的",
				"pagePath":"pages/user/user",
				"iconPath": "/static/TabbarLogo/user.svg",
				"selectedIconPath": "/static/TabbarLogo/user-a.svg"
			}
		]
	},
	"globalStyle": {
		"navigationStyle": "custom", // 隐藏默认导航
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "uni-app",
		"navigationBarBackgroundColor": "#fff",
		"backgroundColor": "#fff"
	},
	"uniIdRouter": {}
}
